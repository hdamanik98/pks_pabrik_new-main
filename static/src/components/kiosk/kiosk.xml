<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    
    <!-- Main Kiosk Template -->
    <t t-name="pks_pabrik.KioskWeighbridge">
        <div class="pks-kiosk-container">
            <!-- Header -->
            <header class="pks-kiosk-header">
                <div class="container-fluid">
                    <div class="row align-items-center">
                        <div class="col-4">
                            <img src="/pks_pabrik/static/src/img/logo.png" alt="PKS Logo" class="pks-kiosk-logo" onerror="this.style.display='none'"/>
                        </div>
                        <div class="col-4 text-center">
                            <h1 class="pks-kiosk-title">KIOSK TIMBANGAN</h1>
                        </div>
                        <div class="col-4 text-end">
                            <div class="pks-kiosk-clock">
                                <t t-out="new Date().toLocaleTimeString('id-ID')"/>
                            </div>
                        </div>
                    </div>
                </div>
            </header>
            
            <!-- Main Content -->
            <main class="pks-kiosk-main">
                <div class="container-fluid">
                    <!-- Idle Mode - RFID Scan -->
                    <t t-if="state.mode === 'idle'">
                        <div class="pks-kiosk-idle">
                            <div class="row justify-content-center">
                                <div class="col-md-8 col-lg-6">
                                    <div class="pks-kiosk-card text-center">
                                        <div class="pks-kiosk-rfid-icon">
                                            <i class="fa fa-wifi fa-5x"/>
                                        </div>
                                        <h2>SCAN RFID TAG</h2>
                                        <p class="text-muted">Tempelkan kartu RFID atau masukkan nomor RFID</p>
                                        
                                        <div class="pks-kiosk-rfid-input">
                                            <input 
                                                type="text" 
                                                id="rfid-input"
                                                class="form-control form-control-lg text-center"
                                                t-model="state.rfidInput"
                                                t-on-input="onRfidInputChange"
                                                placeholder="SCAN RFID..."
                                                autocomplete="off"
                                                autofocus="autofocus"
                                            />
                                        </div>
                                        
                                        <div t-if="state.rfidScanning" class="pks-kiosk-scanning">
                                            <div class="spinner-border text-primary" role="status">
                                                <span class="visually-hidden">Scanning...</span>
                                            </div>
                                            <p class="mt-2">Memproses...</p>
                                        </div>
                                        
                                        <button class="btn btn-primary btn-lg mt-3" t-on-click="processRfidScan" t-att-disabled="state.rfidScanning or !state.rfidInput">
                                            <i class="fa fa-search"/> CARI
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                    
                    <!-- Weigh In Mode -->
                    <t t-if="state.mode === 'weigh_in'">
                        <div class="pks-kiosk-weigh-in">
                            <div class="row justify-content-center">
                                <div class="col-md-10 col-lg-8">
                                    <div class="pks-kiosk-card">
                                        <h2 class="text-center mb-4">
                                            <i class="fa fa-arrow-down text-success"/> TIMBANG MASUK
                                        </h2>
                                        
                                        <!-- Truck Info -->
                                        <div t-if="state.truck" class="pks-kiosk-truck-info mb-4">
                                            <div class="row">
                                                <div class="col-md-6">
                                                    <p><strong>No. Polisi:</strong> <t t-out="state.truck.plate_number"/></p>
                                                    <p><strong>RFID:</strong> <t t-out="state.truck.rfid_tag"/></p>
                                                </div>
                                                <div class="col-md-6">
                                                    <p><strong>Supir:</strong> <t t-out="state.truck.driver or '-'"/></p>
                                                    <p><strong>Status:</strong> <t t-out="state.truck.current_state"/></p>
                                                </div>
                                            </div>
                                        </div>
                                        
                                        <!-- Form -->
                                        <form t-on-submit.prevent="submitWeighIn">
                                            <div class="row">
                                                <div class="col-md-6 mb-3">
                                                    <label class="form-label">Supplier</label>
                                                    <select class="form-select form-select-lg" t-model="state.supplierId" required="required">
                                                        <option value="">Pilih Supplier</option>
                                                        <t t-foreach="state.suppliers" t-as="supplier" t-key="supplier.id">
                                                            <option t-att-value="supplier.id">
                                                                <t t-out="supplier.code"/> - <t t-out="supplier.name"/>
                                                            </option>
                                                        </t>
                                                    </select>
                                                </div>
                                                <div class="col-md-6 mb-3">
                                                    <label class="form-label">Jenis TBS</label>
                                                    <select class="form-select form-select-lg" t-model="state.tbsType">
                                                        <option value="internal">Internal</option>
                                                        <option value="external">Eksternal</option>
                                                        <option value="plasma">Plasma</option>
                                                    </select>
                                                </div>
                                            </div>
                                            
                                            <div class="row">
                                                <div class="col-md-6 mb-3">
                                                    <label class="form-label">Blok Kebun</label>
                                                    <input type="text" class="form-control form-control-lg" t-model="state.estateBlock" placeholder="Contoh: A1, B2"/>
                                                </div>
                                                <div class="col-md-6 mb-3">
                                                    <label class="form-label">Tanggal Panen</label>
                                                    <input type="date" class="form-control form-control-lg" t-model="state.harvestDate"/>
                                                </div>
                                            </div>
                                            
                                            <!-- Weight Input -->
                                            <div class="pks-kiosk-weight-section mb-4">
                                                <label class="form-label">Berat Masuk (kg)</label>
                                                <div class="input-group input-group-lg">
                                                    <input 
                                                        type="number" 
                                                        class="form-control text-end pks-kiosk-weight-input"
                                                        t-model="state.weight"
                                                        placeholder="0"
                                                        step="0.01"
                                                        min="0"
                                                        required="required"
                                                    />
                                                    <button type="button" class="btn btn-secondary" t-on-click="getWeightFromScale" t-att-disabled="state.loading">
                                                        <i class="fa fa-download"/> AMBIL DARI TIMBANGAN
                                                    </button>
                                                </div>
                                                <div t-if="state.weight > 0" class="pks-kiosk-weight-display mt-2">
                                                    <h3 class="text-primary mb-0">
                                                        <t t-out="formattedWeight"/> kg
                                                    </h3>
                                                </div>
                                            </div>
                                            
                                            <!-- Error Message -->
                                            <div t-if="state.error" class="alert alert-danger">
                                                <i class="fa fa-exclamation-triangle"/> <t t-out="state.error"/>
                                            </div>
                                            
                                            <!-- Buttons -->
                                            <div class="row">
                                                <div class="col-6">
                                                    <button type="button" class="btn btn-secondary btn-lg w-100" t-on-click="resetForm">
                                                        <i class="fa fa-times"/> BATAL
                                                    </button>
                                                </div>
                                                <div class="col-6">
                                                    <button type="submit" class="btn btn-success btn-lg w-100" t-att-disabled="state.loading">
                                                        <t t-if="state.loading">
                                                            <span class="spinner-border spinner-border-sm"/>
                                                        </t>
                                                        <t t-else="">
                                                            <i class="fa fa-check"/> SIMPAN
                                                        </t>
                                                    </button>
                                                </div>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                    
                    <!-- Weigh Out Mode -->
                    <t t-if="state.mode === 'weigh_out'">
                        <div class="pks-kiosk-weigh-out">
                            <div class="row justify-content-center">
                                <div class="col-md-10 col-lg-8">
                                    <div class="pks-kiosk-card">
                                        <h2 class="text-center mb-4">
                                            <i class="fa fa-arrow-up text-primary"/> TIMBANG KELUAR
                                        </h2>
                                        
                                        <!-- Ticket Info -->
                                        <div class="pks-kiosk-ticket-info mb-4">
                                            <div class="alert alert-info">
                                                <p class="mb-1"><strong>No. Tiket:</strong> <t t-out="state.ticketNumber or '-'"/></p>
                                                <p class="mb-0"><strong>ID:</strong> <t t-out="state.weighbridgeId"/></p>
                                            </div>
                                        </div>
                                        
                                        <!-- Weight Input -->
                                        <form t-on-submit.prevent="submitWeighOut">
                                            <div class="pks-kiosk-weight-section mb-4">
                                                <label class="form-label">Berat Keluar (kg)</label>
                                                <div class="input-group input-group-lg">
                                                    <input 
                                                        type="number" 
                                                        class="form-control text-end pks-kiosk-weight-input"
                                                        t-model="state.weight"
                                                        placeholder="0"
                                                        step="0.01"
                                                        min="0"
                                                        required="required"
                                                    />
                                                    <button type="button" class="btn btn-secondary" t-on-click="getWeightFromScale" t-att-disabled="state.loading">
                                                        <i class="fa fa-download"/> AMBIL DARI TIMBANGAN
                                                    </button>
                                                </div>
                                                <div t-if="state.weight > 0" class="pks-kiosk-weight-display mt-2">
                                                    <h3 class="text-primary mb-0">
                                                        <t t-out="formattedWeight"/> kg
                                                    </h3>
                                                </div>
                                            </div>
                                            
                                            <!-- Error Message -->
                                            <div t-if="state.error" class="alert alert-danger">
                                                <i class="fa fa-exclamation-triangle"/> <t t-out="state.error"/>
                                            </div>
                                            
                                            <!-- Buttons -->
                                            <div class="row">
                                                <div class="col-6">
                                                    <button type="button" class="btn btn-secondary btn-lg w-100" t-on-click="resetForm">
                                                        <i class="fa fa-times"/> BATAL
                                                    </button>
                                                </div>
                                                <div class="col-6">
                                                    <button type="submit" class="btn btn-primary btn-lg w-100" t-att-disabled="state.loading">
                                                        <t t-if="state.loading">
                                                            <span class="spinner-border spinner-border-sm"/>
                                                        </t>
                                                        <t t-else="">
                                                            <i class="fa fa-check"/> SIMPAN
                                                        </t>
                                                    </button>
                                                </div>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                    
                    <!-- Confirmation Mode -->
                    <t t-if="state.mode === 'confirmation'">
                        <div class="pks-kiosk-confirmation">
                            <div class="row justify-content-center">
                                <div class="col-md-8 col-lg-6">
                                    <div class="pks-kiosk-card text-center">
                                        <div class="pks-kiosk-success-icon mb-4">
                                            <i class="fa fa-check-circle fa-5x text-success"/>
                                        </div>
                                        
                                        <h2 class="text-success">BERHASIL!</h2>
                                        
                                        <div t-if="state.success" class="alert alert-success">
                                            <t t-out="state.success"/>
                                        </div>
                                        
                                        <div class="pks-kiosk-summary mb-4">
                                            <table class="table table-bordered">
                                                <tr>
                                                    <td><strong>No. Tiket</strong></td>
                                                    <td><t t-out="state.ticketNumber or state.weighbridgeId"/></td>
                                                </tr>
                                                <tr>
                                                    <td><strong>Berat</strong></td>
                                                    <td><t t-out="formattedWeight"/> kg</td>
                                                </tr>
                                            </table>
                                        </div>
                                        
                                        <div class="row">
                                            <div class="col-6">
                                                <button class="btn btn-primary btn-lg w-100" t-on-click="printTicket">
                                                    <i class="fa fa-print"/> CETAK
                                                </button>
                                            </div>
                                            <div class="col-6">
                                                <button class="btn btn-success btn-lg w-100" t-on-click="resetForm">
                                                    <i class="fa fa-refresh"/> SELESAI
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </div>
            </main>
            
            <!-- Footer -->
            <footer class="pks-kiosk-footer">
                <div class="container-fluid">
                    <div class="row">
                        <div class="col-12 text-center">
                            <p class="mb-0">PKS Pabrik Management System &copy; 2024</p>
                        </div>
                    </div>
                </div>
            </footer>
        </div>
    </t>
    
</templates>
