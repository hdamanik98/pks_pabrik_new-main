# Environment Variables untuk PKS Pabrik Docker
# =============================================
# Copy file ini ke .env dan sesuaikan nilainya

# Database Configuration
DB_PASSWORD=odoo_secure_password_change_this

# Odoo Admin Password
ADMIN_PASSWORD=admin_secure_password_change_this

# PKS API Token (ganti dengan token yang aman)
PKS_API_TOKEN=your_secure_api_token_here

# PGAdmin Configuration (untuk development)
PGADMIN_EMAIL=admin@pks.local
PGADMIN_PASSWORD=admin_secure_password

# Backup Notification URL (opsional)
# Format: email://user:pass@smtp.host:port/to@email.com
# atau: slack://token@channel
# atau: discord://token@channel
BACKUP_NOTIFICATION_URL=

# SSL Configuration (opsional)
# SSL_CERT_PATH=/path/to/cert.pem
# SSL_KEY_PATH=/path/to/key.pem

# Domain Configuration
DOMAIN=pks.local

# Log Level (debug, info, warning, error)
LOG_LEVEL=info

# Worker Configuration
WORKERS=4
MAX_CRON_THREADS=2

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379

# Email Configuration (opsional)
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password
# EMAIL_FROM=odoo@pks.local
