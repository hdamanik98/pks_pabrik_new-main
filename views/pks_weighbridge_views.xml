<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <!-- ============================================================
             WEIGHBRIDGE VIEWS
        ============================================================ -->
        
        <!-- Tree View -->
        <record id="view_pks_weighbridge_tree" model="ir.ui.view">
            <field name="name">pks.weighbridge.tree</field>
            <field name="model">pks.weighbridge</field>
            <field name="arch" type="xml">
                <tree string="Timbangan" decoration-muted="state=='cancelled'" decoration-info="state=='weighing_in'" decoration-warning="state=='waiting_unload'" decoration-success="state=='done'">
                    <field name="name"/>
                    <field name="create_date"/>
                    <field name="supplier_id"/>
                    <field name="truck_id"/>
                    <field name="weight_in"/>
                    <field name="weight_out"/>
                    <field name="netto_weight"/>
                    <field name="state" widget="badge" decoration-success="state=='done'" decoration-info="state=='weighing_in'" decoration-warning="state=='waiting_unload'" decoration-primary="state=='weighing_out'" decoration-muted="state=='cancelled'"/>
                    <field name="tbs_type"/>
                </tree>
            </field>
        </record>
        
        <!-- Form View -->
        <record id="view_pks_weighbridge_form" model="ir.ui.view">
            <field name="name">pks.weighbridge.form</field>
            <field name="model">pks.weighbridge</field>
            <field name="arch" type="xml">
                <form string="Timbangan">
                    <header>
                        <button name="action_weigh_in" string="Timbang Masuk" type="object" class="btn-primary" invisible="state != 'draft'"/>
                        <button name="action_confirm_arrival" string="Konfirmasi Kedatangan" type="object" class="btn-primary" invisible="state != 'weighing_in'"/>
                        <button name="action_weigh_out" string="Timbang Keluar" type="object" class="btn-primary" invisible="state != 'waiting_unload'"/>
                        <button name="action_done" string="Selesai" type="object" class="btn-success" invisible="state != 'weighing_out'"/>
                        <button name="action_cancel" string="Batalkan" type="object" class="btn-danger" invisible="state in ('done', 'cancelled')"/>
                        <button name="action_reset_to_draft" string="Reset ke Draft" type="object" class="btn-secondary" invisible="state != 'cancelled'" groups="pks_pabrik.group_pks_manager"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,weighing_in,waiting_unload,weighing_out,done"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name" readonly="1"/>
                            </h1>
                        </div>
                        <group>
                            <group string="Informasi">
                                <field name="supplier_id" options="{'no_create': True}"/>
                                <field name="truck_id" options="{'no_create': True}"/>
                                <field name="driver_id" options="{'no_create': True}"/>
                                <field name="tbs_type"/>
                                <field name="estate_block"/>
                                <field name="harvest_date"/>
                                <field name="rfid_tag" readonly="1"/>
                            </group>
                            <group string="Quality">
                                <field name="quality_id" readonly="1"/>
                            </group>
                        </group>
                        <group string="Timbangan">
                            <group>
                                <field name="weight_in"/>
                                <field name="weight_in_datetime" readonly="1"/>
                                <field name="weight_in_operator_id" readonly="1"/>
                            </group>
                            <group>
                                <field name="weight_out"/>
                                <field name="weight_out_datetime" readonly="1"/>
                                <field name="weight_out_operator_id" readonly="1"/>
                            </group>
                        </group>
                        <group>
                            <group>
                                <field name="netto_weight" readonly="1" class="oe_subtotal_footer_separator"/>
                            </group>
                        </group>
                        <group string="Pembatalan" invisible="state != 'cancelled'">
                            <group>
                                <field name="cancel_reason" readonly="1"/>
                                <field name="cancelled_by" readonly="1"/>
                                <field name="cancelled_date" readonly="1"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Catatan">
                                <field name="notes"/>
                            </page>
                        </notebook>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids" groups="base.group_user"/>
                        <field name="activity_ids"/>
                        <field name="message_ids"/>
                    </div>
                </form>
            </field>
        </record>
        
        <!-- Kanban View -->
        <record id="view_pks_weighbridge_kanban" model="ir.ui.view">
            <field name="name">pks.weighbridge.kanban</field>
            <field name="model">pks.weighbridge</field>
            <field name="arch" type="xml">
                <kanban class="o_kanban_mobile" default_group_by="state">
                    <field name="name"/>
                    <field name="supplier_id"/>
                    <field name="truck_id"/>
                    <field name="weight_in"/>
                    <field name="weight_out"/>
                    <field name="netto_weight"/>
                    <field name="state"/>
                    <field name="tbs_type"/>
                    <templates>
                        <t t-name="kanban-box">
                            <div t-attf-class="oe_kanban_global_click">
                                <div class="o_kanban_record_top">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title">
                                            <span><t t-esc="record.name.value"/></span>
                                        </strong>
                                    </div>
                                    <span class="float-end">
                                        <field name="state" widget="label_selection" options="{'classes': {'draft': 'default', 'weighing_in': 'info', 'waiting_unload': 'warning', 'weighing_out': 'primary', 'done': 'success', 'cancelled': 'muted'}}"/>
                                    </span>
                                </div>
                                <div class="o_kanban_record_body">
                                    <div>Supplier: <t t-esc="record.supplier_id.value"/></div>
                                    <div>Truk: <t t-esc="record.truck_id.value"/></div>
                                    <div>Jenis: <t t-esc="record.tbs_type.value"/></div>
                                    <div>Masuk: <t t-esc="record.weight_in.value"/> kg</div>
                                    <div>Keluar: <t t-esc="record.weight_out.value"/> kg</div>
                                    <div><strong>Netto: <t t-esc="record.netto_weight.value"/> kg</strong></div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>
        
        <!-- Search View -->
        <record id="view_pks_weighbridge_search" model="ir.ui.view">
            <field name="name">pks.weighbridge.search</field>
            <field name="model">pks.weighbridge</field>
            <field name="arch" type="xml">
                <search string="Cari Timbangan">
                    <field name="name"/>
                    <field name="supplier_id"/>
                    <field name="truck_id"/>
                    <field name="rfid_tag"/>
                    <filter name="filter_today" string="Hari Ini" domain="[('create_date', '>=', context_today().strftime('%Y-%m-%d'))]"/>
                    <filter name="filter_this_week" string="Minggu Ini" domain="[('create_date', '>=', (context_today() - relativedelta(weeks=1)).strftime('%Y-%m-%d'))]"/>
                    <filter name="filter_this_month" string="Bulan Ini" domain="[('create_date', '>=', (context_today() - relativedelta(months=1)).strftime('%Y-%m-%d'))]"/>
                    <filter name="filter_draft" string="Draft" domain="[('state', '=', 'draft')]"/>
                    <filter name="filter_weighing_in" string="Timbang Masuk" domain="[('state', '=', 'weighing_in')]"/>
                    <filter name="filter_waiting_unload" string="Menunggu Bongkar" domain="[('state', '=', 'waiting_unload')]"/>
                    <filter name="filter_done" string="Selesai" domain="[('state', '=', 'done')]"/>
                    <filter name="filter_internal" string="Internal" domain="[('tbs_type', '=', 'internal')]"/>
                    <filter name="filter_external" string="Eksternal" domain="[('tbs_type', '=', 'external')]"/>
                    <filter name="filter_plasma" string="Plasma" domain="[('tbs_type', '=', 'plasma')]"/>
                    <group expand="0" string="Group By">
                        <filter name="group_by_state" string="Status" context="{'group_by': 'state'}"/>
                        <filter name="group_by_supplier" string="Supplier" context="{'group_by': 'supplier_id'}"/>
                        <filter name="group_by_tbs_type" string="Jenis TBS" context="{'group_by': 'tbs_type'}"/>
                        <filter name="group_by_date" string="Tanggal" context="{'group_by': 'create_date:day'}"/>
                    </group>
                </search>
            </field>
        </record>
        
        <!-- Graph View -->
        <record id="view_pks_weighbridge_graph" model="ir.ui.view">
            <field name="name">pks.weighbridge.graph</field>
            <field name="model">pks.weighbridge</field>
            <field name="arch" type="xml">
                <graph string="Statistik Timbangan" type="bar">
                    <field name="create_date" interval="day"/>
                    <field name="netto_weight" type="measure"/>
                </graph>
            </field>
        </record>
        
        <!-- Pivot View -->
        <record id="view_pks_weighbridge_pivot" model="ir.ui.view">
            <field name="name">pks.weighbridge.pivot</field>
            <field name="model">pks.weighbridge</field>
            <field name="arch" type="xml">
                <pivot string="Analisis Timbangan">
                    <field name="create_date" type="row" interval="day"/>
                    <field name="supplier_id" type="row"/>
                    <field name="netto_weight" type="measure"/>
                    <field name="weight_in" type="measure"/>
                    <field name="weight_out" type="measure"/>
                </pivot>
            </field>
        </record>
        
        <!-- Calendar View -->
        <record id="view_pks_weighbridge_calendar" model="ir.ui.view">
            <field name="name">pks.weighbridge.calendar</field>
            <field name="model">pks.weighbridge</field>
            <field name="arch" type="xml">
                <calendar string="Jadwal Timbangan" date_start="create_date" color="state">
                    <field name="name"/>
                    <field name="supplier_id"/>
                    <field name="netto_weight"/>
                    <field name="state"/>
                </calendar>
            </field>
        </record>
        
        <!-- Action -->
        <record id="action_pks_weighbridge" model="ir.actions.act_window">
            <field name="name">Timbangan</field>
            <field name="res_model">pks.weighbridge</field>
            <field name="view_mode">tree,kanban,form,graph,pivot,calendar</field>
            <field name="search_view_id" ref="view_pks_weighbridge_search"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Buat tiket timbangan pertama
                </p>
                <p>
                    Tiket timbangan digunakan untuk mencatat berat TBS masuk dan keluar.
                </p>
            </field>
        </record>
        
    </data>
</odoo>
