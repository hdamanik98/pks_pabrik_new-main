<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <!-- ============================================================
             TRUCK VIEWS
        ============================================================ -->
        
        <!-- Tree View -->
        <record id="view_pks_truck_tree" model="ir.ui.view">
            <field name="name">pks.truck.tree</field>
            <field name="model">pks.truck</field>
            <field name="arch" type="xml">
                <tree string="Truk" decoration-muted="current_state=='maintenance'" decoration-info="current_state=='in_weighbridge'" decoration-success="current_state=='available'">
                    <field name="name"/>
                    <field name="rfid_tag"/>
                    <field name="truck_type"/>
                    <field name="brand" optional="hide"/>
                    <field name="capacity_kg"/>
                    <field name="current_state" widget="badge" decoration-success="current_state=='available'" decoration-info="current_state=='in_weighbridge'" decoration-warning="current_state=='in_mill'" decoration-danger="current_state=='maintenance'"/>
                    <field name="driver_id"/>
                    <field name="total_trips"/>
                    <field name="total_weight_delivered"/>
                    <field name="last_activity_date"/>
                </tree>
            </field>
        </record>
        
        <!-- Form View -->
        <record id="view_pks_truck_form" model="ir.ui.view">
            <field name="name">pks.truck.form</field>
            <field name="model">pks.truck</field>
            <field name="arch" type="xml">
                <form string="Truk">
                    <header>
                        <button name="action_set_maintenance" string="Set Maintenance" type="object" class="btn-warning" invisible="current_state == 'maintenance'"/>
                        <button name="action_set_available" string="Set Tersedia" type="object" class="btn-success" invisible="current_state != 'maintenance'"/>
                        <button name="action_schedule_maintenance" string="Jadwalkan Maintenance" type="object" class="btn-secondary"/>
                        <field name="current_state" widget="statusbar" statusbar_visible="available,in_weighbridge,in_mill,maintenance,inactive"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="action_view_weighbridges" type="object" class="oe_stat_button" icon="fa-truck">
                                <field name="total_trips" widget="statinfo" string="Trip"/>
                            </button>
                            <button name="action_view_on_map" type="object" class="oe_stat_button" icon="fa-map-marker" invisible="last_gps_latitude == 0">
                                <span>Lokasi</span>
                            </button>
                        </div>
                        <div class="oe_title">
                            <h1>
                                <field name="name" placeholder="No. Polisi"/>
                            </h1>
                        </div>
                        <group>
                            <group string="Informasi Truk">
                                <field name="rfid_tag"/>
                                <field name="truck_type"/>
                                <field name="brand"/>
                                <field name="model_year"/>
                                <field name="capacity_kg"/>
                                <field name="ownership"/>
                                <field name="supplier_id" invisible="ownership != 'third_party'"/>
                            </group>
                            <group string="Dokumen">
                                <field name="stnk_number"/>
                                <field name="stnk_expiry"/>
                                <field name="kir_expiry"/>
                                <field name="driver_id"/>
                            </group>
                        </group>
                        <group string="Status &amp; Lokasi">
                            <group>
                                <field name="current_state"/>
                                <field name="last_activity"/>
                                <field name="last_activity_date"/>
                            </group>
                            <group>
                                <field name="current_location"/>
                                <field name="last_gps_latitude"/>
                                <field name="last_gps_longitude"/>
                                <field name="last_gps_update"/>
                            </group>
                        </group>
                        <group string="Statistik">
                            <group>
                                <field name="total_trips" readonly="1"/>
                                <field name="total_weight_delivered" readonly="1"/>
                                <field name="average_trip_weight" readonly="1"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Maintenance">
                                <field name="maintenance_ids">
                                    <tree>
                                        <field name="name"/>
                                        <field name="date"/>
                                        <field name="maintenance_type"/>
                                        <field name="cost"/>
                                        <field name="state"/>
                                    </tree>
                                </field>
                            </page>
                            <page string="History Timbangan">
                                <field name="weighbridge_ids">
                                    <tree>
                                        <field name="name"/>
                                        <field name="create_date"/>
                                        <field name="supplier_id"/>
                                        <field name="netto_weight"/>
                                        <field name="state"/>
                                    </tree>
                                </field>
                            </page>
                            <page string="Catatan">
                                <field name="notes"/>
                            </page>
                        </notebook>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids" groups="base.group_user"/>
                        <field name="activity_ids"/>
                        <field name="message_ids"/>
                    </div>
                </form>
            </field>
        </record>
        
        <!-- Kanban View -->
        <record id="view_pks_truck_kanban" model="ir.ui.view">
            <field name="name">pks.truck.kanban</field>
            <field name="model">pks.truck</field>
            <field name="arch" type="xml">
                <kanban class="o_kanban_mobile">
                    <field name="name"/>
                    <field name="rfid_tag"/>
                    <field name="truck_type"/>
                    <field name="current_state"/>
                    <field name="driver_id"/>
                    <field name="total_trips"/>
                    <templates>
                        <t t-name="kanban-box">
                            <div t-attf-class="oe_kanban_global_click">
                                <div class="o_kanban_record_top">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title">
                                            <span><t t-esc="record.name.value"/></span>
                                        </strong>
                                    </div>
                                    <span class="float-end">
                                        <field name="current_state" widget="label_selection" options="{'classes': {'available': 'success', 'in_weighbridge': 'info', 'in_mill': 'warning', 'maintenance': 'danger', 'inactive': 'default'}}"/>
                                    </span>
                                </div>
                                <div class="o_kanban_record_body">
                                    <div>RFID: <t t-esc="record.rfid_tag.value"/></div>
                                    <div>Tipe: <t t-esc="record.truck_type.value"/></div>
                                    <div>Supir: <t t-esc="record.driver_id.value"/></div>
                                    <div>Total Trip: <t t-esc="record.total_trips.value"/></div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>
        
        <!-- Search View -->
        <record id="view_pks_truck_search" model="ir.ui.view">
            <field name="name">pks.truck.search</field>
            <field name="model">pks.truck</field>
            <field name="arch" type="xml">
                <search string="Cari Truk">
                    <field name="name"/>
                    <field name="rfid_tag"/>
                    <field name="driver_id"/>
                    <filter name="filter_available" string="Tersedia" domain="[('current_state', '=', 'available')]"/>
                    <filter name="filter_in_weighbridge" string="Di Timbangan" domain="[('current_state', '=', 'in_weighbridge')]"/>
                    <filter name="filter_maintenance" string="Maintenance" domain="[('current_state', '=', 'maintenance')]"/>
                    <filter name="filter_own" string="Milik Sendiri" domain="[('ownership', '=', 'own')]"/>
                    <filter name="filter_rent" string="Sewa" domain="[('ownership', '=', 'rent')]"/>
                    <group expand="0" string="Group By">
                        <filter name="group_by_state" string="Status" context="{'group_by': 'current_state'}"/>
                        <filter name="group_by_type" string="Tipe" context="{'group_by': 'truck_type'}"/>
                        <filter name="group_by_ownership" string="Kepemilikan" context="{'group_by': 'ownership'}"/>
                    </group>
                </search>
            </field>
        </record>
        
        <!-- Action -->
        <record id="action_pks_truck" model="ir.actions.act_window">
            <field name="name">Truk</field>
            <field name="res_model">pks.truck</field>
            <field name="view_mode">tree,kanban,form</field>
            <field name="search_view_id" ref="view_pks_truck_search"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Daftarkan truk pertama Anda
                </p>
                <p>
                    Truk digunakan untuk mengangkut TBS dari kebun ke pabrik.
                </p>
            </field>
        </record>
        
        <!-- Graph View -->
        <record id="view_pks_truck_graph" model="ir.ui.view">
            <field name="name">pks.truck.graph</field>
            <field name="model">pks.truck</field>
            <field name="arch" type="xml">
                <graph string="Statistik Truk" type="bar">
                    <field name="truck_type"/>
                    <field name="total_trips" type="measure"/>
                    <field name="total_weight_delivered" type="measure"/>
                </graph>
            </field>
        </record>
        
    </data>
</odoo>
